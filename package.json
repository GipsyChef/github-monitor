{
  "name": "github-monitor",
  "version": "1.0.0",
  "description": "Local visual dashboard for open GitHub PRs, CI, CD, deployments, and runners.",
  "type": "module",
  "license": "MIT",
  "author": "Yoni",
  "homepage": "https://github.com/GipsyChef/github-monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GipsyChef/github-monitor.git"
  },
  "bugs": {
    "url": "https://github.com/GipsyChef/github-monitor/issues"
  },
  "keywords": [
    "github",
    "pull-requests",
    "ci",
    "cd",
    "ci-cd",
