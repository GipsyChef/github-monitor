# GitHub Monitor configuration — copy to `.env` and fill in as needed.
# `.env` is gitignored. Never commit real tokens or private keys.
#
# Authentication: pick ONE path.
#
# 1) Personal access token (simplest). If unset, the server falls back to
#    `gh auth token` from a locally authenticated GitHub CLI.
# GITHUB_TOKEN=
# GH_TOKEN=
#
# 2) GitHub App (higher quota, per-installation rate limits).
#    See docs/github-app-setup.md. Store the private key OUTSIDE this repo
#    with file mode 0600.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem

# --- Optional tuning -------------------------------------------------------

# Port for the local dashboard (default: 4177).
# PORT=4177

# Parallelism for the open-PR scan (default chosen automatically).
# OPEN_PRS_JOBS=4

# Set to 1 to disable conditional-request ETag caching (debugging only).
# ETAG_CACHE_DISABLED=
